    "def save_recipe(recipe_text):\n",
    "\n",
    "    embedding = embedding_model.encode(recipe_text)\n",
    "\n",
    "    collection.add(\n",
    "    ids=[str(uuid.uuid4())],\n",
    "    documents=[recipe_text],\n",
    "    embeddings=[embedding.tolist()],\n",
    "    metadatas=[{\n",
    "        \"ingredients\" : \",\".join(items),\n",
    "        \"liked\": True\n",
    "    }]\n",
    ")"
   ]
